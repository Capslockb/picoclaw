# Phase1 runtime environment
# Copy to /etc/picoclaw/phase1.env and edit values.

# Telegram alerts + recovery (required for Telegram recovery and outbound alerts)
TELEGRAM_BOT_TOKEN=__SET_ME__
TELEGRAM_CHAT_ID=__SET_ME__

# PicoClaw gateway checks
# Use 18790 for a direct gateway install.
# Only use 3000 when you have a local reverse proxy or hub in front of the gateway.
PICOCLAW_GATEWAY=http://127.0.0.1:18790
PICOCLAW_UNIT=picoclaw.service
DISK_WARN_PERCENT=90
